<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".Screen2Fragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">


        <!-- Image de fond avec alpha -->
        <ImageView
            android:id="@+id/backgroundImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0.3"
            android:scaleType="centerCrop"
            android:src="@drawable/fond"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="1.0" />


        <CheckBox
            android:id="@+id/checkHumain"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:text="Humains Impliqués"
            android:textSize="25sp"
            android:layout_marginHorizontal="30dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="UseSwitchCompatOrMaterialXml" />

        <TextView
            android:id="@+id/textView2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="Si il y a des humain impactés dans l'accident"
            app:layout_constraintStart_toStartOf="@+id/checkHumain"
            app:layout_constraintTop_toBottomOf="@id/checkHumain" />

        <!-- Ajout du LinearLayout avec l'ID layoutBlessure pour correspondre au Java -->
        <LinearLayout
            android:id="@+id/layoutBlessure"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/textView2">

            <TextView
                android:id="@+id/textView3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="30dp"
                android:layout_marginTop="5dp"
                android:text="Blessures :"
                android:textSize="25sp" />

            <!-- RadioGroup pour les blessures avec l'ID radioBlessure -->
            <RadioGroup
                android:id="@+id/radioBlessure"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/radioModeree"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Modéré" />

                <RadioButton
                    android:id="@+id/radioGraveBlessure"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Graves"/>
            </RadioGroup>
        </LinearLayout>


        <TextView
            android:id="@+id/textView5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="30dp"
            android:text="Description :"
            android:textSize="25sp"
            android:layout_marginTop="20dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/layoutBlessure" />

        <EditText
            android:id="@+id/editDescription"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_marginHorizontal="30dp"
            android:background="@drawable/fond_champ_texte"
            android:gravity="top|start"
            android:hint="Saisir une description de l'incident..."
            android:inputType="textMultiLine"
            android:layout_marginTop="10dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView5" />

        <TextView
            android:id="@+id/textView4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="30dp"
            android:layout_marginTop="20dp"
            android:text="Gravité Globale :"
            android:textSize="25sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/editDescription" />

        <!-- Changement de l'ID radioGroup2 en radioGroup pour correspondre au Java -->
        <RadioGroup
            android:id="@+id/radioGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="30dp"
            android:orientation="vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView4">

            <!-- IDs des boutons radio pour correspondre au Java -->
            <RadioButton
                android:id="@+id/radioFaible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Faible"
                android:checked="true"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/textDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:layout_marginBottom="0dp"
                android:text="Peu de dégâts matériels/humains"
                android:textColor="#666666" />

            <RadioButton
                android:id="@+id/radioMoyen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Moyen"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/textDescription2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:text="Dégâts matériels, risques humains"
                android:textColor="#666666" />

            <RadioButton
                android:id="@+id/radioGrave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Urgent"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/textDescription3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:text="Dégâts humains/matériels importants."
                android:textColor="#666666" />

        </RadioGroup>

        <!-- Ajout de l'ID btnValider -->
        <Button
            android:id="@+id/btnValider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="30dp"
            android:text="Valider"
            android:layout_marginTop="5dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/radioGroup" />

    </androidx.constraintlayout.widget.ConstraintLayout>



</FrameLayout>
